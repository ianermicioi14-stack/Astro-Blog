---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/button.astro';
import { db } from '@/db';
import { posts } from '@/db/schema';
// fs and path removed for Cloudflare Workers compatibility

const isAuthenticated = Astro.cookies.has('auth');
if (!isAuthenticated) {
    return Astro.redirect('/login');
}

const currentUserId = Astro.cookies.get('userId')?.value;

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title') as string;
    const excerpt = data.get('excerpt') as string;
    const content = data.get('content') as string;
    const imageFile = data.get('image') as File | null;

    if (!title || !excerpt || !content) {
      error = 'Title, excerpt, and content are required.';
    } else {
      const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');

      let imagePath = null;
      if (imageFile && imageFile.size > 0) {
          const buffer = await imageFile.arrayBuffer();
          const base64 = Buffer.from(buffer).toString('base64');
          imagePath = `data:${imageFile.type};base64,${base64}`;
      }

      await db.insert(posts).values({
        title,
        slug,
        excerpt,
        content,
        image: imagePath,
        authorId: currentUserId ? parseInt(currentUserId) : null,
        createdAt: new Date(),
      });
      return Astro.redirect(`/blog/${slug}`);
    }
  } catch (e: any) {
    const msg = e.message || '';
    if (msg.includes('UNIQUE KEY constraint') || msg.includes('duplicate key')) {
      error = 'A post with this title already exists. Please try a different title.';
    } else {
      error = `Error: ${msg || 'An error occurred while saving the post.'}`;
      console.error(e);
    }
  }
}
---

<Layout title="New Post | Astro Blog">
    <div class="max-w-2xl mx-auto w-full animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="mb-8 flex items-center justify-between">
            <h1 class="text-3xl font-bold text-white tracking-tight">Create New Post</h1>
            <Button variant="ghost" as="a" href="/" class="text-muted-foreground hover:text-white">
                Cancel
            </Button>
        </div>
        
        {error && (
            <div class="mb-6 p-4 rounded-xl bg-destructive/10 border border-destructive/20 text-destructive text-sm font-medium">
                {error}
            </div>
        )}

        <form method="POST" enctype="multipart/form-data" class="space-y-6 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 shadow-2xl">
            <div class="space-y-2">
                <label class="text-sm font-medium text-white/90" for="title">Title</label>
                <input type="text" id="title" name="title" class="w-full h-11 px-4 rounded-xl border border-white/10 bg-black/20 text-white placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all" placeholder="My Awesome Post" required />
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-white/90" for="image">Cover Image</label>
                <input type="file" id="image" name="image" accept="image/*" class="w-full px-4 py-2.5 rounded-xl border border-white/10 bg-black/20 text-white file:mr-4 file:py-1 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-500 transition-all" />
                <p class="text-[11px] text-muted-foreground">Upload a photo to be used as the blog post cover.</p>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-white/90" for="excerpt">Excerpt</label>
                <textarea id="excerpt" name="excerpt" rows="2" class="w-full p-4 rounded-xl border border-white/10 bg-black/20 text-white placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all resize-none" placeholder="A short summary of your post..." required></textarea>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-white/90" for="content">Content</label>
                <textarea id="content" name="content" rows="10" class="w-full p-4 rounded-xl border border-white/10 bg-black/20 text-white placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all" placeholder="Write your content here..." required></textarea>
            </div>
            
            <div class="pt-4 flex justify-end">
                <Button type="submit" class="rounded-xl px-8 h-11 bg-blue-600 hover:bg-blue-500 text-white font-medium transition-all shadow-lg shadow-blue-500/20">
                    Publish Post
                </Button>
            </div>
        </form>
    </div>
</Layout>
