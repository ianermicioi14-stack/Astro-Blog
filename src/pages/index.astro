---
import Layout from '@/layouts/Layout.astro';
import { db } from '@/db';
import { posts } from '@/db/schema';
import Button from '@/components/ui/button.astro';
import Search from '@/components/Search.astro';
import { like, or, desc } from 'drizzle-orm';

const query = Astro.url.searchParams.get('q') || '';

let allPosts;
if (query) {
    const searchPattern = `%${query}%`;
    allPosts = await db.select()
        .from(posts)
        .where(
            or(
                like(posts.title, searchPattern),
                like(posts.excerpt, searchPattern),
                like(posts.content, searchPattern)
            )
        )
        .orderBy(desc(posts.createdAt));
} else {
    allPosts = await db.select().from(posts).orderBy(desc(posts.createdAt));
}
---

<Layout title="Home | Astro Blog">
    <div class="space-y-12 animate-in fade-in slide-in-from-bottom-4 duration-1000">
        <div class="flex flex-col md:flex-row md:items-end justify-between space-y-6 md:space-y-0 mb-4">
            <div class="space-y-4 text-center md:text-left">
                <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-400 to-emerald-400 pb-2">
                    Welcome to the Future
                </h1>
                <p class="text-lg text-muted-foreground max-w-2xl mx-auto md:mx-0">
                    A blazing fast, ultra-modern blog built with Astro, full.dev UI, and Drizzle ORM on top of SQL Server.
                </p>
            </div>
            <div class="flex flex-col items-center md:items-end space-y-4 pb-2">
                <Button variant="default" as="a" href="/post/new" class="rounded-full shadow-lg shadow-blue-500/20 px-6 h-11 transition-all hover:shadow-blue-500/40 hover:-translate-y-0.5 bg-blue-600 hover:bg-blue-500 text-white border border-blue-500/50">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                    New Post
                </Button>
            </div>
        </div>
        
        {query && (
            <div class="flex items-center justify-between border-b border-white/10 pb-4 mb-2">
                <p class="text-muted-foreground">
                    Showing results for <span class="text-white font-semibold">"{query}"</span>
                </p>
                <a href="/" class="text-sm font-medium text-blue-500 hover:text-blue-400 transition-colors flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    Clear search
                </a>
            </div>
        )}

        <div class="grid gap-6 sm:grid-cols-2">
            {allPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group relative rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-6 shadow-xl transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 hover:border-blue-500/50 hover:bg-white/10">
                    <div class="flex flex-col space-y-3 h-full">
                        <h2 class="text-2xl font-semibold tracking-tight text-white group-hover:text-blue-400 transition-colors">
                            {post.title}
                        </h2>
                        <p class="text-sm text-muted-foreground line-clamp-3 flex-grow leading-relaxed">
                            {post.excerpt}
                        </p>
                        <div class="pt-4 flex items-center text-sm font-medium text-blue-500">
                            Read Article
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </div>
                    </div>
                </a>
            ))}
        </div>

        {allPosts.length === 0 && (
            <div class="py-20 text-center space-y-4 rounded-2xl border border-dashed border-white/10 bg-white/5">
                <div class="flex justify-center text-muted-foreground">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
                </div>
                <div class="space-y-1">
                    <h3 class="text-xl font-semibold text-white">No posts found</h3>
                    <p class="text-muted-foreground">Try adjusting your search or browse all posts.</p>
                </div>
                <Button as="a" href="/" variant="outline" class="mt-4 rounded-full">
                    Clear Search
                </Button>
            </div>
        )}
        
        <div class="pt-8 flex justify-center md:justify-start">
            <Button as="a" href="/archives" variant="outline" class="rounded-full px-8 h-12 text-sm font-medium backdrop-blur-md border-white/10 hover:bg-white/10 hover:text-white transition-all duration-300">
                View All Archives
            </Button>
        </div>
    </div>
</Layout>
