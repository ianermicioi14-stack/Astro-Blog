---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/button.astro';
import { db } from '@/db';
import { users } from '@/db/schema';
import { eq } from 'drizzle-orm';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const email = data.get('email') as string;
    const password = data.get('password') as string;

    if (!email || !password) {
      error = 'Email and password are required.';
    } else if (email === 'admin' && password === 'admin') {
      // Hardcoded superadmin
      Astro.cookies.set('auth', 'true', { path: '/' });
      Astro.cookies.set('email', 'admin', { path: '/' });
      Astro.cookies.set('username', 'Admin', { path: '/' });
      Astro.cookies.set('userId', '1', { path: '/' });
      Astro.cookies.set('isAdmin', 'true', { path: '/' });
      return Astro.redirect('/');
    } else {
      const userRecords = await db.select().from(users).where(eq(users.email, email));
      const user = userRecords[0];

      if (!user) {
        error = 'Invalid email or password.';
      } else {
        const isValid = await Bun.password.verify(password, user.passwordHash);
        if (isValid) {
          Astro.cookies.set('auth', 'true', { path: '/' });
          Astro.cookies.set('email', email, { path: '/' });
          Astro.cookies.set('username', user.username, { path: '/' });
          Astro.cookies.set('userId', String(user.id), { path: '/' });
          if (user.isAdmin) {
            Astro.cookies.set('isAdmin', 'true', { path: '/' });
          }
          return Astro.redirect('/');
        } else {
          error = 'Invalid email or password.';
        }
      }
    }
  } catch (e: any) {
    const msg = e.message || '';
    error = `Error: ${msg || 'An error occurred during login.'}`;
    console.error(e);
  }
}
---

<Layout title="Login | Astro Blog">
    <div class="max-w-md mx-auto w-full pt-10 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 shadow-2xl">
            <div class="mb-8 text-center">
                <h1 class="text-3xl font-bold text-white tracking-tight mb-2">Sign In</h1>
                <p class="text-muted-foreground text-sm">Enter your email and password to continue.</p>
            </div>
            
            {error && (
                <div class="mb-6 p-4 rounded-xl bg-destructive/10 border border-destructive/20 text-destructive text-sm font-medium">
                    {error}
                </div>
            )}

            <form method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-white/90" for="email">Email</label>
                    <input type="text" id="email" name="email" class="w-full h-11 px-4 rounded-xl border border-white/10 bg-black/20 text-white placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all" placeholder="you@example.com" required />
                </div>
                
                <div class="space-y-2">
                    <label class="text-sm font-medium text-white/90" for="password">Password</label>
                    <input type="password" id="password" name="password" class="w-full h-11 px-4 rounded-xl border border-white/10 bg-black/20 text-white placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all" placeholder="••••••••" required />
                </div>
                
                <Button type="submit" class="w-full rounded-xl h-11 bg-blue-600 hover:bg-blue-500 text-white font-medium transition-all shadow-lg shadow-blue-500/20">
                    Sign In
                </Button>
            </form>
            
            <p class="mt-6 text-center text-sm text-muted-foreground">
                Don't have an account? <a href="/signup" class="text-blue-400 hover:text-blue-300 font-medium">Sign up</a>
            </p>
        </div>
    </div>
</Layout>
